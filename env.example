# Esempio di variabili d'ambiente per sviluppo
# Copia questo file come .env e inserisci i valori appropriati

# Supabase (frontend - variabili pubbliche)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Supabase (server / funzioni) - NON mettere il service role key in .env pubblico
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_URL=

# AI gateway (usato da funzioni serverless)
AI_GATEWAY_URL=https://ai.gateway.lovable.dev
AI_GATEWAY_KEY=

# Creditsafe (esempio)
CLOSESAFE_API_KEY=

# RNA API (esempio)
RNA_API_KEY=

# Push notifications (VAPID) - utilizzate dalle funzioni
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Altre variabili (esempi)
NODE_ENV=development

# Note:
# - Le chiavi sensibili (service role) devono essere memorizzate come secret nell'ambiente di hosting o nel CI.
# - Non commitare mai chiavi private su repo pubblico.
